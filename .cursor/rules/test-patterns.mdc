```python
@pytest.fixture(params=[
    Money("100.00"),
    Money("50.25"), 
    Money("0.01"),
])
def various_money_amounts(request):
    return request.param
```

## Anti-Patterns to Avoid

### 1. ❌ Class-Based Tests
```python
# DON'T DO THIS
class TestMoney:
    def test_addition(self):
        pass
```

### 2. ❌ Multiple Asserts
```python
# DON'T DO THIS
def test_money_properties():
    money = Money("100.50")
    assert money.real_amount == Decimal("100.50")  # Multiple asserts
    assert money.cents == 10050
    assert money.is_positive()
```

### 3. ❌ Conditional Logic
```python
# DON'T DO THIS
def test_money_comparison():
    money1 = Money("100")
    money2 = Money("50")
    if money1 > money2:
        assert True
    else:
        assert False
```

### 4. ❌ Vague Test Names
```python
# DON'T DO THIS
def test_money_1():
def test_addition():
def test_works():
```

### 5. ❌ Calculations in Tests
```python
# DON'T DO THIS - Calculations hide bugs and make tests unclear
def test_settlement_totals():
    settlement = loan.record_payment(Money("800.00"), date)
    
    # Bad: Calculation in test
    total = sum(a.principal_allocated + a.interest_allocated 
                for a in settlement.allocations)
    assert total == Money("800.00")
    
    # Bad: Complex computation
    expected_coverage = (settlement.allocations[0].principal_allocated >= 
                        original_schedule[0].principal_payment)
    assert settlement.allocations[0].is_fully_covered == expected_coverage

# DO THIS INSTEAD - Assert exact values
def test_settlement_exact_allocation_values():
    settlement = loan.record_payment(Money("800.00"), date)
    
    # Good: Exact values
    assert settlement.allocations[0].principal_allocated == Money("292.99")
    assert settlement.allocations[0].interest_allocated == Money("10.63")
    assert settlement.allocations[0].is_fully_covered is True
    
    assert settlement.allocations[1].principal_allocated == Money("297.18")
    assert settlement.allocations[1].is_fully_covered is False
```

## Example: Complete Test File Structure

```python
"""Tests for Money class - following project patterns."""

import pytest
from decimal import Decimal
from money_warp.money import Money


# Creation tests
@pytest.mark.parametrize("amount,expected", [
    ("100.50", Decimal("100.50")),
    (100, Decimal("100.00")),
    (Decimal("100.50"), Decimal("100.50")),
])
def test_money_creation_from_various_types(amount, expected):
    money = Money(amount)
    assert money.real_amount == expected


def test_money_creation_zero_class_method():
    money = Money.zero()
    assert money.is_zero()


# Arithmetic tests
def test_money_addition_basic_amounts():
    money1 = Money("100.50")
    money2 = Money("50.25")
    result = money1 + money2
    assert result.real_amount == Decimal("150.75")


def test_money_division_maintains_high_precision():
    money = Money("100.00")
    result = money / 3
    assert result.raw_amount == Decimal("100.00") / 3


# Comparison tests
def test_money_equality_same_amounts():
    money1 = Money("100.50")
    money2 = Money("100.50")
    assert money1 == money2


# Property tests
def test_money_cents_property_conversion():
    money = Money("123.45")
    assert money.cents == 12345


# Edge case tests
def test_money_very_small_amount_rounds_down():
    money = Money("0.001")
    assert money.real_amount == Decimal("0.00")


# Settlement tests - demonstrating exact values pattern
def test_settlement_allocation_exact_values():
    """Example of asserting exact values instead of calculations."""
    loan = create_test_loan()
    
    # Assert expected installment amounts (exact values)
    original_schedule = loan.get_original_schedule()
    assert original_schedule[0].payment_amount == Money("303.62")
    assert original_schedule[1].payment_amount == Money("303.62")
    
    # Make payment and assert exact allocation values
    settlement = loan.record_payment(Money("800.00"), payment_date)
    
    # Assert exact allocated amounts (no calculations)
    assert settlement.allocations[0].principal_allocated == Money("292.99")
    assert settlement.allocations[0].interest_allocated == Money("10.63")
    assert settlement.allocations[0].is_fully_covered is True
    
    assert settlement.allocations[1].principal_allocated == Money("297.18")
    assert settlement.allocations[1].interest_allocated == Money("0.00")
    assert settlement.allocations[1].is_fully_covered is False
```

---

**Remember**: Keep tests simple, focused, and deterministic. Assert exact values, not calculations! 🧪